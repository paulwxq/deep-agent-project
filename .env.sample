# ============================================================
# deep-agent-project 环境变量配置
# 复制本文件为 .env 并填入实际的 API Key
# cp .env.sample .env
# ============================================================

# ----------------------------------------------------------
# DashScope（阿里云百炼） —— Qwen 系列模型
# 获取地址：https://bailian.console.aliyun.com/
# 接入方式：LangChain 原生集成（langchain-qwq 包 → ChatQwen 类）
# 注意：langchain-qwq 默认使用国际端点，国内用户必须设置 DASHSCOPE_API_BASE
# ----------------------------------------------------------
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# ----------------------------------------------------------
# MiniMaxi —— MiniMax-M2.7 / MiniMax-M2.5
# 获取地址：https://platform.minimaxi.com/
# 接入方式：Anthropic API 兼容模式
# Base URL：https://api.minimaxi.com/anthropic
# ----------------------------------------------------------
MINIMAX_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------------------------------------
# BigModel / 智谱 AI —— GLM-5 / GLM-4.7
# 获取地址：https://open.bigmodel.cn/
# 接入方式：OpenAI API 兼容模式
# Base URL：https://open.bigmodel.cn/api/paas/v4/
# ----------------------------------------------------------
ZHIPUAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------------------------------------
# OpenRouter —— 海外模型代理（OpenAI / Claude 等）
# 获取地址：https://openrouter.ai/keys
# 接入方式：LangChain 原生 openrouter: 前缀
# ----------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------------------------------------
# Tavily —— Web 搜索工具（可选）
# 获取地址：https://tavily.com/
# 在 config/agents.yaml 中 tools.tavily.enabled 为 true 时需要
# ----------------------------------------------------------
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------------------------------------
# LangSmith —— Agent 追踪与调试（可选）
# 获取地址：https://smith.langchain.com/
# ----------------------------------------------------------
# LANGSMITH_API_KEY=lsv2-xxxxxxxxxxxxxxxxxxxxxxxx
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=deep-agent-project
